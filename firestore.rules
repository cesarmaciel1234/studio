rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Permitimos lectura y escritura completa para prototipado rápido a usuarios autenticados.
      // Esto previene errores de "Missing or insufficient permissions" en listados de pedidos y chats.
      allow read, write: if request.auth != null;
    }
  }
}