rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD PARA RUTARÁPIDA PRO
    // Permite lectura y escritura a cualquier usuario autenticado (incluyendo anónimos)
    // para todas las colecciones. Esto asegura que los repartidores puedan ver pedidos,
    // alertas y perfiles de otros conductores sin errores de permisos.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}