rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas simplificadas para prototipado: permite lectura y escritura a cualquier usuario autenticado.
    // Esto garantiza que el listado de perfiles y la actualización de ubicación funcionen sin errores.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}