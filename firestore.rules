
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla de acceso total para prototipado rápido
    // Permite lectura y escritura a cualquier usuario para asegurar que el seguimiento GPS,
    // perfiles, pedidos y alertas comunitarias funcionen sin bloqueos de permisos.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
