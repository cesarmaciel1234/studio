
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla de desarrollo: Permite acceso a usuarios autenticados para evitar errores de permisos 
    // en la creación de perfiles iniciales de Empresa y Repartidor.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
