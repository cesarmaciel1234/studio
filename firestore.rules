
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas de seguridad globales para prototipado rápido
    // Permite lectura y escritura a cualquier usuario autenticado
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas específicas para asegurar que las operaciones de listado funcionen sin problemas
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
      match /chatMessages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
