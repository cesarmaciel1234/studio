
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla global simplificada para prototipo: permite todo a usuarios autenticados
    // Esto evita conflictos de permisos en alertas, perfiles y seguimiento GPS
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
