rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD PARA RUTARÁPIDA PRO
    // Se permite acceso total de lectura y escritura a cualquier usuario autenticado (incluyendo anónimos)
    // para facilitar el prototipado y la colaboración en tiempo real.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}