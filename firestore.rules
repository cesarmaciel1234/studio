rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Regla global permisiva para desarrollo: permite lectura y escritura a usuarios autenticados
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}