
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLA GLOBAL: Permite acceso total para prototipado rápido y seguimiento GPS en tiempo real.
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Reglas explícitas para colecciones principales
    match /users/{userId} {
      allow read, write: if true;
    }
    match /driverProfiles/{driverId} {
      allow read, write: if true;
    }
    match /companyProfiles/{companyId} {
      allow read, write: if true;
    }
    match /orders/{orderId} {
      allow read, write: if true;
    }
    match /alerts/{alertId} {
      allow read, write: if true;
    }
  }
}
