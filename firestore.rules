rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Permitir lectura y escritura completa a cualquier usuario autenticado
      // Esto es ideal para prototipos en Studio y evita errores de permisos al listar colecciones.
      allow read, write: if request.auth != null;
    }
  }
}