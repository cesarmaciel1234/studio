
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLA GLOBAL DE DESARROLLO: Permite acceso total de lectura y escritura.
    // Esto garantiza que el seguimiento GPS, perfiles, pedidos y alertas funcionen sin bloqueos de permisos.
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Reglas explícitas para mayor claridad en el motor de Firebase
    match /users/{userId} {
      allow read, write: if true;
    }
    match /driverProfiles/{driverId} {
      allow read, write: if true;
    }
    match /companyProfiles/{companyId} {
      allow read, write: if true;
    }
    match /orders/{orderId} {
      allow read, write: if true;
    }
    match /alerts/{alertId} {
      allow read, write: if true;
    }
  }
}
