rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Permitir lectura y escritura completa a cualquier usuario autenticado (incluyendo anónimos)
      // Esto soluciona errores de "Missing or insufficient permissions" al listar o consultar colecciones.
      allow read, write: if request.auth != null;
    }
  }
}