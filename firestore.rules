rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLA GLOBAL: Permite lectura y escritura a cualquier usuario autenticado.
    // Ideal para prototipado rápido y garantiza que no haya bloqueos en las colecciones.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas explícitas para colecciones críticas para reforzar el acceso.
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /driverProfiles/{driverId} {
      allow read, write: if request.auth != null;
    }
    
    match /companyProfiles/{companyId} {
      allow read, write: if request.auth != null;
    }
    
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }
    
    match /orders/{orderId}/messages/{messageId} {
      allow read, write: if request.auth != null;
    }
    
    match /alerts/{alertId}/comments/{commentId} {
      allow read, write: if request.auth != null;
    }
  }
}