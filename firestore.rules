rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD PARA RUTARÁPIDA PRO
    // Se permite lectura y escritura a cualquier usuario autenticado (incluyendo anónimos)
    // para todas las colecciones principales de la logística.
    
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /driverProfiles/{driverId} {
      allow read, write: if request.auth != null;
    }
    
    match /companyProfiles/{companyId} {
      allow read, write: if request.auth != null;
    }
    
    match /vehicles/{vehicleId} {
      allow read, write: if request.auth != null;
    }
    
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
      
      match /chatMessages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }
    
    // Regla comodín de respaldo para desarrollo
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}