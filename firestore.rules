rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLA GLOBAL DE PROTOTIPADO: Permite lectura y escritura a cualquier usuario autenticado.
    // Esto garantiza que el sistema de login, perfiles y seguimiento GPS funcione sin bloqueos de permisos.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}