rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- REGLAS DE SEGURIDAD PARA RUTARÁPIDA PRO ---
    // En esta fase de prototipo, permitimos acceso completo de lectura y escritura 
    // a cualquier usuario que haya iniciado sesión (incluyendo login anónimo).
    // Esto asegura que las consultas de lista (list) en colecciones como /orders 
    // funcionen correctamente para conductores y administradores.

    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Nota: El despliegue de estas reglas se activa automáticamente al guardar este archivo.
  }
}