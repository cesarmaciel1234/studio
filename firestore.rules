rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLA GLOBAL DE PROTOTIPADO: Permite lectura y escritura total para agilizar el desarrollo.
    // Esto asegura que el seguimiento GPS en tiempo real, la creación de perfiles,
    // los likes de comunidad y los chats funcionen sin bloqueos de permisos.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}