rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE AYUDA ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGLAS DE COLECCIONES ---

    /**
     * @description Reglas para usuarios.
     * Cualquier usuario autenticado puede leer perfiles para ver la flota.
     */
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    /**
     * @description Perfiles específicos por rol.
     */
    match /driverProfiles/{driverId} {
      allow read: if isSignedIn();
      allow write: if isOwner(driverId);
    }

    match /companyProfiles/{companyId} {
      allow read: if isSignedIn();
      allow write: if isOwner(companyId);
    }

    /**
     * @description Pedidos logísticos.
     * Permitimos lectura (get y list) a todos los usuarios firmados para que los conductores vean ofertas.
     */
    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn();

      match /chatMessages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    /**
     * @description Alertas viales y SOS.
     */
    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    /**
     * @description Gestión de vehículos.
     */
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}