
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas universales para prototipado rápido: permite lectura y escritura a cualquier usuario autenticado (incluyendo anónimos)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas explícitas para asegurar que las operaciones de listado ('list') no sean bloqueadas por el SDK
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
      match /chatMessages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
