
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas universales para usuarios autenticados (incluyendo anónimos)
    // Se permite lectura y escritura en todas las colecciones para facilitar el flujo de la MVP.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas explícitas para colecciones principales para asegurar el listado (list)
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
      match /chatMessages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
