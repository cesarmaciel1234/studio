rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permite a cualquier usuario autenticado leer y escribir en su propio perfil
    match /driverProfiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    match /companyProfiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Permite lectura y escritura general a usuarios autenticados para pedidos y alertas
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }
    
    // Regla global de respaldo para desarrollo
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}