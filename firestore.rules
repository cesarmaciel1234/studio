
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLA GLOBAL: Permite acceso total para prototipado rápido.
    // Esto asegura que el seguimiento GPS, perfiles, pedidos y alertas funcionen sin bloqueos.
    match /{document=**} {
      allow read, write: if true;
    }

    // REGLAS EXPLÍCITAS: Refuerzan el acceso a colecciones críticas para el sistema de logística.
    match /users/{userId} {
      allow read, write: if true;
    }
    match /driverProfiles/{driverId} {
      allow read, write: if true;
    }
    match /companyProfiles/{companyId} {
      allow read, write: if true;
    }
    match /orders/{orderId} {
      allow read, write: if true;
    }
    match /alerts/{alertId} {
      allow read, write: if true;
    }
    match /alerts/{alertId}/comments/{commentId} {
      allow read, write: if true;
    }
    match /orders/{orderId}/messages/{messageId} {
      allow read, write: if true;
    }
  }
}
