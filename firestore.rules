
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Perfiles de usuario (General)
    match /users/{userId} {
      allow get, list, write: if isSignedIn();
    }

    // Perfiles de conductores
    match /driverProfiles/{driverId} {
      allow get, list, write: if isSignedIn();
    }

    // Perfiles de empresas/admins
    match /companyProfiles/{companyId} {
      allow get, list, write: if isSignedIn();
    }

    // Pedidos
    match /orders/{orderId} {
      allow read, list, create, update, delete: if isSignedIn();
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // Alertas y Comunidad
    match /alerts/{alertId} {
      allow read, list, create, update: if isSignedIn();
      allow delete: if isSignedIn() && (resource == null || resource.data.authorId == request.auth.uid);

      match /comments/{commentId} {
        allow read, list, create: if isSignedIn();
      }
    }

    // Roles Administrativos
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
    }
  }
}
