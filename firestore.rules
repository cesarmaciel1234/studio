rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLA GLOBAL DE PROTOTIPADO: Permite lectura y escritura a cualquier usuario autenticado.
    // Esto garantiza que el sistema de login y perfiles funcione sin bloqueos iniciales.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas explícitas para colecciones maestras para asegurar la visibilidad de roles.
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /driverProfiles/{driverId} {
      allow read, write: if request.auth != null;
    }
    
    match /companyProfiles/{companyId} {
      allow read, write: if request.auth != null;
    }
    
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }
  }
}