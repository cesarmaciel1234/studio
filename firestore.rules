rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // PERMISOS PRO: Permitir lectura y escritura a cualquier usuario autenticado
      // Esto soluciona los errores de "Missing or insufficient permissions" al listar colecciones
      allow read, write: if request.auth != null;
    }
  }
}