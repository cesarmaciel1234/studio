
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permite lectura y escritura a cualquier usuario autenticado en todas las colecciones.
    // Esto asegura que los conductores anónimos puedan listar pedidos, alertas y mensajes.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas explícitas para mayor seguridad y claridad en el depurador
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
      match /chatMessages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
