
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para prototipado: permite acceso total a usuarios autenticados
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas específicas para asegurar que list() funcione en colecciones principales
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
      match /chatMessages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
