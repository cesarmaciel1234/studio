rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS GLOBALES PARA PROTOTIPO
    // Permitimos acceso completo de lectura y escritura a cualquier usuario autenticado.
    // Esto es necesario para que los repartidores anónimos puedan listar pedidos,
    // crear alertas y actualizar su ubicación sin fricción.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}