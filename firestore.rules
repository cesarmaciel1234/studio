
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla global para prototipo: permite lectura y escritura a cualquier usuario autenticado
    // Esto asegura que el seguimiento GPS, perfiles y alertas funcionen sin bloqueos de permisos.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Despliegue forzado: Mar-2024
  }
}
