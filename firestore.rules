rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla global para permitir lectura y escritura a cualquier usuario autenticado
    // Esto facilita el desarrollo y prototipado rápido de las funciones de Empresa y Driver
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}