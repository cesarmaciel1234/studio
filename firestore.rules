rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Reglas para usuarios.
     * Permitimos lectura general para facilitar la visibilidad de la flota.
     */
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
    }

    /**
     * @description Perfiles de conductores y empresas.
     */
    match /driverProfiles/{driverId} {
      allow read: if isSignedIn();
      allow write: if isOwner(driverId);
    }

    match /companyProfiles/{companyId} {
      allow read: if isSignedIn();
      allow write: if isOwner(companyId);
    }

    /**
     * @description Pedidos logísticos.
     * Todos los conductores deben poder LISTAR pedidos para aceptarlos.
     */
    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn();

      match /chatMessages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    /**
     * @description Alertas viales (Coro Driver).
     */
    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    /**
     * @description Vehículos.
     */
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}