
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas de seguridad globales robustas para el prototipo
    // Permite lectura y escritura a cualquier usuario autenticado (incluyendo anónimos)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas específicas por colección para asegurar operaciones de listado ('list')
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
      match /chatMessages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
