rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD PARA RUTARÁPIDA PRO
    // Se permite acceso total a usuarios autenticados para agilizar el prototipado y la colaboración.
    // Se definen permisos explícitos de 'list' para evitar errores de consulta en colecciones raíz.

    match /users/{userId} {
      allow get, list, write: if request.auth != null;
    }

    match /driverProfiles/{id} {
      allow get, list, write: if request.auth != null;
    }

    match /companyProfiles/{id} {
      allow get, list, write: if request.auth != null;
    }

    match /vehicles/{id} {
      allow get, list, write: if request.auth != null;
    }

    match /orders/{id} {
      allow get, list, write: if request.auth != null;
      
      match /chatMessages/{msgId} {
        allow get, list, write: if request.auth != null;
      }
    }

    match /alerts/{id} {
      allow get, list, write: if request.auth != null;
    }

    // Backup catch-all
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}